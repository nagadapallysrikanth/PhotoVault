# ─────────────────────────────────────────────────────────
# PhotoVault — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────

# ── Storage ───────────────────────────────────────────────
# Your SSD path (change to match your Windows username)
SSD_PATH=C:/Users/YourName/Pictures/PhotoVault

# Your external HDD path (change drive letter if needed)
EXTERNAL_PATH=D:/PhotoVault

# Where thumbnails are cached (auto-created)
THUMBNAIL_DIR=C:/Users/YourName/.photovault/thumbnails

# ── App Settings ──────────────────────────────────────────
APP_NAME=PhotoVault
APP_HOST=0.0.0.0
APP_PORT=5000
DEBUG=true

# Max upload size in MB
MAX_UPLOAD_MB=200

# ── Admin Account (auto-created on first run) ─────────────
# Change these BEFORE first run, or change password after first login
ADMIN_USERNAME=admin
ADMIN_EMAIL=you@youremail.com
ADMIN_PASSWORD=ChangeMe123

# ── Security (Phase 2) ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Max failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Email Notifications (Phase 4) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
NOTIFY_EMAIL=your@gmail.com

# ── Push Notifications (Phase 4) ──────────────────────────
# Free service — see https://ntfy.sh
NTFY_TOPIC=photovault-your-unique-topic
NTFY_SERVER=https://ntfy.sh

# ── Wake-on-LAN (Phase 6) ─────────────────────────────────
# Your PC's MAC address (find with: ipconfig /all on Windows)
PC_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
# Your PC's local IP (set as static in your router)
PC_LOCAL_IP=192.168.1.100

# ── AI Tagging (Phase 8) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Cloudflare Tunnel (Phase 5) ───────────────────────────
# Your tunnel URL after setup (e.g. photovault.yourdomain.com)
PUBLIC_URL=https://photovault.yourdomain.com
